{
  "name": "docs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/generate-discovery.ts && node scripts/build-diagrams.ts && node scripts/copy-vocs-theme.ts && node scripts/generate-cli-help.ts && vite build",
    "check": "biome check --write",
    "check:ci": "biome check",
    "check:sdk-drift": "npx tsx .github/actions/sdk-drift-check/check-sdk-drift.ts",
    "check:types": "tsc --noEmit",
    "dev": "vite dev",
    "generate:discovery": "node scripts/generate-discovery.ts",
    "preinstall": "pnpx only-allow pnpm",
    "prepare": "pnpm simple-git-hooks",
    "preview": "vite preview",
    "sync:vocs": "node scripts/copy-vocs-theme.ts && pnpm check",
    "test": "vitest run",
    "test:e2e": "VITE_SKIP_ANIMATION=true VITE_DEMO_LIVE=false vitest run --config vitest.config.e2e.ts",
    "test:watch": "viest"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@stripe/stripe-js": "^8.9.0",
    "@vercel/blob": "^2.3.1",
    "mermaid": "^11.12.2",
    "mppx": "~0.4.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "stripe": "^20.4.1",
    "tailwindcss": "^4.1.18",
    "viem": "^2.47.5",
    "vocs": "https://pkg.pr.new/wevm/vocs@319c55c",
    "wagmi": "^3.4.2",
    "waku": "^1.0.0-alpha.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.1",
    "@iconify/json": "^2.2.433",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "ajv": "8",
    "ajv-formats": "^3.0.1",
    "happy-dom": "^20.8.9",
    "playwright": "^1.58.2",
    "simple-git-hooks": "^2.13.1",
    "tiktoken": "^1.0.22",
    "typescript": "^5",
    "unplugin-icons": "^23.0.1",
    "vite": "^7.3.5",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@hono/node-server": "^1.19.10",
      "@vitejs/plugin-rsc": "^0.5.26",
      "express-rate-limit": "^8.2.2",
      "fast-uri": "^3.1.2",
      "hono": "^4.12.25",
      "lodash-es": "^4.18.0",
      "path-to-regexp": "^8.4.0",
      "picomatch": "^4.0.4",
      "react-server-dom-webpack": "^19.2.6",
      "rollup@4": "^4.59.0",
      "serialize-javascript": "^7.0.3",
      "undici": "^6.27.0"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  }
}
